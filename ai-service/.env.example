# ai-service/.env
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Groq LLM ──────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Current supported models (as of 2025):
#   openai/gpt-oss-120b       ← recommended (best quality)
#   llama-3.1-8b-instant      ← fastest / cheapest
#   mixtral-8x7b-32768        ← alternative
GROQ_MODEL=openai/gpt-oss-120b

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Hugging Face Serverless Inference API token
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hf_token_here
HF_API_KEY=your_hf_key_here

# ── FAISS index paths ─────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index/index.faiss
FAISS_METADATA_PATH=data/faiss_index/metadata.json

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
