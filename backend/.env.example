# ================================
# Server
# ================================
PORT=5000
NODE_ENV=development

# ================================
# MongoDB Atlas
# ================================
# Get this from: https://cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/wellness_bot?retryWrites=true&w=majority

# ================================
# JWT
# ================================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ================================
# Python AI Service
# ================================
# URL of the running FastAPI service
AI_SERVICE_URL=http://localhost:8000

# ================================
# (Optional) Rate limiting
# ================================
# Max requests per 15 minutes per IP (for /api/chat routes)
CHAT_RATE_LIMIT=50
